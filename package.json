{
  "name": "nextjs-study",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js + TypeScript 학습 저장소 — 실무 투입 가능 수준까지",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "lesson": "tsx",
    "lesson:idioms-ts": "tsx lessons/05_idioms/01_typescript_idioms.ts",
    "lesson:idioms-ts-learn": "tsx lessons/05_idioms/01_typescript_idioms.learn.ts"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "server-only": "^0.0.1",
    "client-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "tailwindcss": "^3.4.16",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
